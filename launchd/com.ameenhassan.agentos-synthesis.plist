<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ameenhassan.agentos-synthesis</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/ameenhassan/Desktop/Tech &amp; Coding/Coding_projects/ameen-context-mcp/hooks/run_synthesis.sh</string>
    </array>

    <!-- Run every Sunday at 02:00 local time -->
    <key>StartCalendarInterval</key>
