        <integer>0</integer>
        <key>Hour</key>
        <integer>2</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/ameenhassan/Desktop/Tech &amp; Coding/Coding_projects/ameen-context-mcp/data/_synthesis_launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/ameenhassan/Desktop/Tech &amp; Coding/Coding_projects/ameen-context-mcp/data/_synthesis_launchd.log</string>

    <!-- Do NOT run immediately on launchctl load -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
